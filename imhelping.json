{
  "session": {
    "name": "example-loop",
    "workdir": ".",
    "progress": "examples/PROGRESS.md",
    "logs": "logs/imhelping",
    "addDirs": [],
    "watchGit": ["."],
    "watchFiles": [],
    "maxSteps": 40,
    "retrySleep": 3600,
    "retryMax": 24,
    "logAfter": ""
  },
  "implementation": {
    "engine": "codex",
    "prompt": "prompts/base-implementation.md",
    "status": "DONE"
  },
  "reviews": [
    {
      "key": "review-a",
      "enabled": true,
      "engine": "claude",
      "prompt": "prompts/base-review-with-simplify.md",
      "status": "REVIEWED-A"
    },
    {
      "key": "verify",
      "enabled": false,
      "engine": "claude",
      "prompt": "prompts/base-verifier.md",
      "status": "VERIFIED",
      "itemFilter": "[VERIFY]",
      "verdictFile": "logs/verdict.json",
      "blockOnVerdictFail": true,
      "cleanupAfter": true
    }
  ]
}
